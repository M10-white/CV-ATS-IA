{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skibidi Melyha 67",
  "version": "0.2.0",
  "identifier": "com.cv-architect.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Skibidi Melyha 67",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNFNkY3OEU1QTkzRkEzNUUKUldSZW96K3A1WGh2UHV2Myt5b2pVZ1Y5YzBmWmU0VU1rc1VPME1ibVJHVG1qeHp1YXdFQkhyT0wK",
      "endpoints": [
        "https://github.com/M10-white/CV-ATS-IA/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
